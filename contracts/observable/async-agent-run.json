          "maxGlobalChildRuns": {
            "type": "integer",
            "minimum": 0
          },
          "maxChildRunsPerParent": {
            "type": "integer",
            "minimum": 0
          },
          "maxSpawnDepth": {
            "type": "integer",
            "minimum": 0
          },
          "maxChildrenPerRun": {
            "type": "integer",
            "minimum": 0
          },
          "allowChildSpawn": {
            "type": "boolean"
          },
          "cancelPropagation": {
            "type": "string",
            "enum": ["none", "direct-children", "subtree"]
          }
        }
      },
      "activity": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "phase": {
            "type": "string",
            "enum": [
              "queued",
              "starting",
              "model_request",
              "tool_execution",
              "permission_wait",
              "child_wait",
              "scheduler_wait",
              "external_wait",
              "retry_sleep",
              "completed",
              "failed",
              "cancelled",
              "stalled"
