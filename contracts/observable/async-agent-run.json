          },
          "currentTarget": {
            "type": "string"
          },
          "currentToolName": {
            "type": "string"
          },
          "currentIteration": {
            "type": "integer",
            "minimum": 0
          },
          "interruptible": {
            "type": "boolean"
          },
          "stallReason": {
            "type": "string"
          }
        }
      },
      "kind": {
        "type": "string",
        "enum": [
          "agent.run",
          "subagent.run",
          "workflow.run",
          "autonomous.run"
        ]
      },
      "agent": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          }
        }
      },
      "status": {
