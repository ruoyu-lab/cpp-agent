            "type": "array"
          },
          "childRuns": {
            "type": "array"
          }
        }
      },
      "metadata": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "statusMachine": {
    "initial": "queued",
    "statuses": [
      "queued",
      "running",
      "waiting",
      "completed",
      "failed",
      "cancelled"
    ],
    "closedStatuses": ["completed", "cancelled"],
    "resumableStatuses": [
      "waiting",
      "failed"
    ],
    "transitions": [
      {
        "from": "queued",
        "to": ["running", "cancelled"]
      },
      {
        "from": "running",
        "to": [
          "waiting",
          "completed",
          "failed",
          "cancelled",
          "queued"
        ]
      },
      {
        "from": "waiting",
        "to": ["queued", "cancelled"]
      },
      {
        "from": "failed",
        "to": ["queued", "cancelled"]
      },
      {
        "from": "completed",
        "to": []
      },
      {
        "from": "cancelled",
        "to": []
      }
    ]
  },
  "eventTypes": [
    "async_run.created",
    "async_run.queued",
    "async_run.started",
    "async_run.heartbeat",
    "async_run.activity",
    "async_run.stream_event",
    "async_run.checkpoint.created",
    "async_run.transcript.appended",
    "async_run.approval.requested",
    "async_run.approval.resolved",
    "async_run.waiting",
    "async_run.resume.requested",
    "async_run.resumed",
    "async_run.cancel.requested",
    "async_run.cancelled",
    "async_run.completed",
    "async_run.failed",
    "async_run.interrupted",
    "async_run.lease.expired",
    "child.run.queued",
    "child.run.started",
    "child.run.heartbeat",
    "child.run.activity",
    "child.run.stalled",
    "child.run.ledger.updated",
    "child.run.completed",
    "child.run.failed",
    "child.run.cancelled"
  ],
  "operationTypes": [
    "async_agent_run.start",
    "async_agent_run.read",
    "async_agent_run.cancel",
    "async_agent_run.resume",
    "async_agent_run.list_events",
    "async_agent_run.list_checkpoints",
    "async_agent_run.list_transcript",
    "child_agent.start",
    "child_agent.read",
    "child_agent.cancel",
    "child_agent.resume"
  ],
  "schedulerBoundary": {
    "interface": "AsyncAgentRunScheduler",
    "operations": [
      {
        "name": "createWakeup",
        "input": {
          "runId": "string",
          "notBefore": "rfc3339-string",
          "reason": "string",
          "metadata": "object"
        },
        "output": {
          "wakeupId": "string",
          "provider": "string"
        }
      },
      {
        "name": "cancelWakeup",
        "input": {
          "runId": "string",
          "wakeupId": "string",
          "reason": "string"
        },
        "output": {
          "cancelled": "boolean"
        }
      }
    ],
    "frameworkResponsibilities": [
      "persist run status before calling host scheduler",
      "record scheduler wakeup metadata on the run",
      "resume a due run by transitioning waiting with reason=schedule to queued",
      "emit async_run.waiting and async_run.resumed events"
    ],
    "hostResponsibilities": [
      "provide durable timers or app lifecycle wakeups",
      "call the framework resume entrypoint when a wakeup fires",
      "surface scheduler failures as async_run.failed or async_run.interrupted",
      "avoid platform APIs inside the framework core"
    ]
  },
  "streamObservation": {
    "interface": "AsyncAgentRunWorkerConfig.on_stream_event",
    "delivery": "synchronous-in-worker",
    "payloadSource": "AgentRunnerStreamEvent normalized to JSON",
    "hostResponsibilities": [
      "project events to UI, CLI, logs, sockets, or language bindings",
      "catch best-effort transport failures when event projection must not fail the run",
      "keep durable storage behind AsyncAgentRunStore, RunTranscript, or host adapters"
    ],
    "toolCallArgumentDeltaPayload": {
      "type": "tool-call-argument-delta",
      "iteration": 1,
      "provider": "openai",
      "model": "gpt-4.1",
      "toolCallId": "call_001",
      "toolName": "fs.writeText",
      "argsDelta": "{\"path\"",
      "argsAccumulated": "{\"path\""
    }
  },
  "ffi": {
    "encoding": "utf8-json",
    "ids": "opaque strings",
    "timestamps": "RFC3339 UTC strings",
    "ownership": "caller owns returned JSON strings and releases them with the binding's string-free function",
    "rule": "C, C#, Rust, Swift, Python, and other bindings exchange only JSON documents at this boundary; no language futures, promises, threads, or platform timer handles cross the ABI."
  },
