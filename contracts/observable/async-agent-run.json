{
  "version": 1,
  "protocol": "async-agent-run",
  "schema": {
    "type": "object",
    "required": [
      "schemaVersion",
      "runId",
      "kind",
      "status",
      "attempt",
      "createdAt",
      "updatedAt",
      "metadata"
    ],
    "additionalProperties": true,
    "properties": {
      "schemaVersion": {
        "type": "integer",
        "enum": [1]
      },
      "runId": {
        "type": "string",
        "minLength": 1
      },
      "parentRunId": {
        "type": "string"
      },
      "rootRunId": {
        "type": "string"
      },
      "depth": {
        "type": "integer",
        "minimum": 0
      },
      "role": {
        "type": "string",
        "enum": ["leaf", "orchestrator"]
      },
      "parentChildRelation": {
        "type": "string"
      },
      "spawnedByToolCallId": {
        "type": "string"
      },
      "topology": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "parentRunId": {
            "type": "string"
          },
          "rootRunId": {
            "type": "string"
          },
          "depth": {
            "type": "integer",
            "minimum": 0
          },
          "role": {
            "type": "string",
            "enum": ["leaf", "orchestrator"]
          },
          "parentChildRelation": {
