{
  "version": 1,
  "cases": [
    {
      "name": "event bus defaults to no sinks and raw payloads disabled",
      "subject": "eventBus",
      "expected": {
        "includeRaw": false,
        "sinks": []
      }
    },
    {
      "name": "default hook logger emits trace success and warn failure events",
      "subject": "defaultHookLogger",
      "expected": [
        {
          "level": "trace",
          "message": "hook.tool.success",
          "payload": {
            "toolName": "contract.defaults"
          }
        },
        {
          "level": "warn",
          "message": "hook.tool.error",
          "payload": {
            "toolName": "contract.defaults",
            "message": "default failure",
            "name": "Error"
          }
        }
      ]
    },
    {
      "name": "tool definition defaults are closed and low risk",
      "subject": "toolDefinition",
      "expected": {
        "descriptor": {
          "name": "contract.defaults",
          "description": "",
          "inputSchema": {},
          "readOnly": false,
          "mutatesFiles": false,
          "interactive": false,
          "longRunning": false,
          "batchable": false,
          "concurrencyKey": "",
          "sideEffectLevel": "unknown"
        },
        "capabilities": [],
        "riskLevel": "low",
        "tags": [],
        "builtin": false,
        "description": "",
