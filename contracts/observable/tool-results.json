{
  "version": 1,
  "cases": [
    {
      "name": "plain object result becomes text output and ok metadata",
      "input": {
        "toolCall": {
          "id": "call_plain",
          "name": "contract.plain",
          "arguments": {
            "value": 42
          }
        },
        "result": {
          "answer": 42,
          "unit": "contract"
        }
      },
      "expected": {
        "ok": true,
        "result": {
          "answer": 42,
          "unit": "contract"
        },
        "structuredOutput": {
          "answer": 42,
          "unit": "contract"
        },
        "output": "{\n  \"answer\": 42,\n  \"unit\": \"contract\"\n}",
        "error": null,
        "message": {
          "role": "tool",
          "content": [
            {
              "type": "text",
              "text": "{\n  \"answer\": 42,\n  \"unit\": \"contract\"\n}"
            }
          ],
          "name": "contract.plain",
          "toolCallId": "call_plain",
          "toolCalls": [],
          "metadata": {
            "ok": true
          }
        }
      }
    },
    {
      "name": "result envelope separates model content from machine value",
      "input": {
        "toolCall": {
          "id": "call_envelope",
          "name": "contract.envelope",
          "arguments": {
            "path": "contract/result.json"
          }
        },
        "result": {
          "value": {
            "artifactKey": "artifact://contract/result.json",
            "items": 2
          },
          "content": [
            {
              "type": "file",
              "source": {
                "kind": "artifact",
                "key": "artifact://contract/result.json",
                "mimeType": "application/json",
                "filename": "result.json"
              },
              "title": "Contract result",
              "textHint": "2 contract items",
              "metadata": {
                "audited": true
              }
            }
          ],
          "metadata": {
            "artifactKey": "artifact://contract/result.json"
          }
        }
      },
      "expected": {
        "ok": true,
        "result": {
          "value": {
            "artifactKey": "artifact://contract/result.json",
            "items": 2
          },
          "content": [
            {
              "type": "file",
              "source": {
                "kind": "artifact",
                "key": "artifact://contract/result.json",
                "mimeType": "application/json",
                "filename": "result.json"
              },
              "title": "Contract result",
              "textHint": "2 contract items",
              "metadata": {
                "audited": true
              }
            }
          ],
          "metadata": {
            "artifactKey": "artifact://contract/result.json"
          }
        },
        "structuredOutput": {
          "artifactKey": "artifact://contract/result.json",
          "items": 2
        },
        "output": "{\n  \"artifactKey\": \"artifact://contract/result.json\",\n  \"items\": 2\n}",
        "error": null,
        "message": {
          "role": "tool",
          "content": [
            {
              "type": "file",
              "source": {
                "kind": "artifact",
                "key": "artifact://contract/result.json",
                "mimeType": "application/json",
                "filename": "result.json"
              },
              "title": "Contract result",
              "textHint": "2 contract items",
              "metadata": {
                "audited": true
              }
            }
          ],
          "name": "contract.envelope",
          "toolCallId": "call_envelope",
          "toolCalls": [],
          "metadata": {
            "ok": true,
            "artifactKey": "artifact://contract/result.json"
          }
        }
      }
    },
    {
      "name": "thrown error becomes failed tool result message",
      "input": {
        "toolCall": {
          "id": "call_throw",
          "name": "contract.throw",
          "arguments": {}
        },
        "throws": {
          "message": "contract exploded"
        }
      },
      "expected": {
        "ok": false,
        "structuredOutput": null,
        "output": "{\n  \"ok\": false,\n  \"error\": \"contract exploded\"\n}",
        "error": {
          "name": "ToolExecutionError",
          "message": "Tool \"contract.throw\" failed.",
          "toolName": "contract.throw",
          "toolCallId": "call_throw",
          "cause": {
            "name": "Error",
            "message": "contract exploded"
          }
        },
        "message": {
          "role": "tool",
          "content": [
            {
              "type": "text",
              "text": "{\n  \"ok\": false,\n  \"error\": \"contract exploded\"\n}"
            }
          ],
          "name": "contract.throw",
          "toolCallId": "call_throw",
          "toolCalls": [],
          "metadata": {
            "ok": false
          }
        }
      }
    }
  ]
}
