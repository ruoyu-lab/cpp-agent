{
  "version": 1,
  "cases": [
    {
      "name": "event without trace keeps category target and payload only",
      "input": {
        "category": "system.ready",
        "target": "run",
        "payload": {
          "ok": true
        }
      },
      "expected": {
        "returned": {
          "category": "system.ready",
          "target": "run",
          "payload": {
            "ok": true
          }
        },
        "captured": [
          {
            "category": "system.ready",
            "target": "run",
            "payload": {
              "ok": true
            }
          }
        ]
      }
    },
    {
      "name": "trace context is promoted onto the event envelope",
      "input": {
        "category": "tool.started",
        "target": "tool",
        "traceContext": {
          "traceId": "trace-contract",
          "spanId": "span-tool",
          "spanName": "tool dispatch",
          "runId": "run-contract"
        },
        "payload": {
          "phase": "started",
          "toolName": "contract.tool",
          "toolCallId": "call_contract",
          "iteration": 0,
          "arguments": {
            "command": "npm --version"
          },
          "startedAt": "2026-06-05T00:00:00Z"
        }
      },
      "expected": {
        "returned": {
          "traceId": "trace-contract",
          "spanId": "span-tool",
          "spanName": "tool dispatch",
          "category": "tool.started",
          "target": "tool",
          "payload": {
            "phase": "started",
            "toolName": "contract.tool",
            "toolCallId": "call_contract",
            "iteration": 0,
            "arguments": {
              "command": "npm --version"
            },
            "startedAt": "2026-06-05T00:00:00Z"
          }
        },
        "captured": [
          {
            "traceId": "trace-contract",
            "spanId": "span-tool",
            "spanName": "tool dispatch",
            "category": "tool.started",
            "target": "tool",
            "payload": {
              "phase": "started",
              "toolName": "contract.tool",
              "toolCallId": "call_contract",
              "iteration": 0,
              "arguments": {
                "command": "npm --version"
              },
              "startedAt": "2026-06-05T00:00:00Z"
            }
          }
        ]
      }
    },
    {
      "name": "explicit trace fields win over fallback context",
      "input": {
        "category": "model.completed",
        "target": "model",
        "traceId": "trace-explicit",
        "spanId": "span-model",
        "parentSpanId": "span-run",
        "workflowRunId": "workflow-contract",
        "traceContext": {
          "traceId": "trace-fallback",
          "spanId": "span-fallback"
        },
        "payload": {
          "provider": "fixture",
          "finishReason": "stop"
        }
      },
      "expected": {
        "returned": {
          "traceId": "trace-explicit",
          "spanId": "span-model",
          "parentSpanId": "span-run",
          "workflowRunId": "workflow-contract",
          "category": "model.completed",
          "target": "model",
          "payload": {
            "provider": "fixture",
            "finishReason": "stop"
          }
        },
        "captured": [
          {
            "traceId": "trace-explicit",
            "spanId": "span-model",
            "parentSpanId": "span-run",
            "workflowRunId": "workflow-contract",
            "category": "model.completed",
            "target": "model",
            "payload": {
              "provider": "fixture",
              "finishReason": "stop"
            }
          }
        ]
      }
    }
  ]
}
